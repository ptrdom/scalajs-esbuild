{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": ["github-actions", "npm", "custom.regex"],
  "ignorePaths": [],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "corepack prepare (?<depName>pnpm)@(?<currentValue>\\S+)",
        "corepack prepare (?<depName>yarn)@(?<currentValue>1\\.\\S+)"
      ],
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.*\\.ya?ml$"],
      "matchStrings": ["corepack prepare yarn@(?<currentValue>[2-9]\\d*\\.\\S+)"],
      "depNameTemplate": "yarn",
      "packageNameTemplate": "@yarnpkg/cli",
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["electron", "electron-chromedriver"],
      "groupName": "electron"
    },
    {
      "matchPackageNames": ["yarn"],
      "matchCurrentVersion": "/^1\\./",
      "allowedVersions": "<2.0.0"
    }
  ]
}
